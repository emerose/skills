# scripts/bib.py loads .env automatically, searching: the library home, the
# current directory, every parent of the script, then ~/.env (the recommended
# consolidated location). Real environment variables and earlier files win.
# Put your real keys in ~/.env (chmod 600); this file just documents them.

# Semantic Scholar API key — raises the keyless rate limit so abstract
# enrichment during add/import is reliable instead of mostly HTTP 429.
S2_API_KEY=

# Contact address for the Crossref / NCBI / Unpaywall "polite pools".
BIBLIOGRAPHER_MAILTO=you@example.com

# Bulk-import pipeline only (Datalab PDF parse + OCR, remote embeddings):
DATALAB_API_KEY=
DEEPINFRA_API_KEY=
BIBLIOGRAPHER_EMBEDDING=remote

# Embedding backend (must stay consistent for a given library):
#   BIBLIOGRAPHER_EMBED_MODEL=qwen3_600m            # default; dim 1024
#   BIBLIOGRAPHER_ALLOW_EMBEDDER_MISMATCH=1         # override the embedder-identity check (rarely)

# Resolver response cache (diskcache). Optional:
#   BIBLIOGRAPHER_CACHE_DIR=   # default: platform user-cache dir (~/Library/Caches/bibliographer)
#   BIBLIOGRAPHER_CACHE_TTL=2592000   # seconds; default 30 days
#   BIBLIOGRAPHER_NO_CACHE=1   # disable the resolver cache entirely

# libkit's own parse/embed cache (shared, content-addressed). Relocate via libkit's
# standard knob if desired:
#   LIBKIT_CACHE_DIR=
